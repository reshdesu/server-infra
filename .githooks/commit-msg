#!/bin/bash
# .githooks/commit-msg - Enforce Conventional Commits

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Regex for Conventional Commits
# e.g., feat(api): add new endpoint
# e.g., fix: resolve crash
PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9_-]+\))?: .+"

if [[ ! "$COMMIT_MSG" =~ $PATTERN ]]; then
    echo -e "${RED}ERROR: Invalid commit message format!${NC}"
    echo -e "This repository enforces Conventional Commits standard."
    echo -e "Your commit message was: ${YELLOW}$COMMIT_MSG${NC}"
    echo -e ""
    echo -e "Valid types: ${GREEN}feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert${NC}"
    echo -e ""
    echo -e "Examples:"
    echo -e "  ${GREEN}feat: add new backup script${NC}"
    echo -e "  ${GREEN}fix(docker): resolve port conflict${NC}"
    echo -e "  ${GREEN}docs: update readme instructions${NC}"
    echo -e ""
    echo -e "Please edit your commit message and try again."
    exit 1
fi

exit 0
