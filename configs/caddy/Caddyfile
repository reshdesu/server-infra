# Caddy configuration for secure local Arr stack access
# Replace your-media-center.ts.net with your actual Tailscale domain, local IP, or public domain
your-media-center.ts.net {
    # Sonarr
    reverse_proxy /sonarr* localhost:8989

    # Radarr
    reverse_proxy /radarr* localhost:7878

    # Prowlarr
    reverse_proxy /prowlarr* localhost:9696

    # SABnzbd
    reverse_proxy /sabnzbd* localhost:8080

    # Serve static dashboard for the root domain /
    root * /var/www/dashboard
    file_server
}
